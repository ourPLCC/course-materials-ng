{
	"name": "Course Materials Dev Container",
	"image": "mcr.microsoft.com/devcontainers/python:3.12-bullseye",

	"customizations": {
		"vscode": {
			"settings": {
				"plantuml.server": "https://www.plantuml.com/plantuml",
				"plantuml.render": "PlantUMLServer"
			},
			"extensions": [
				"jebbs.plantuml"
			]
		}
	},

	"postStartCommand": "make install"
}
